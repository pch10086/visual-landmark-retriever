# Python runtime/cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments and local package installs
.venv/
venv/
env/
myenv/
*.egg-info/
conda-meta/

# OS/editor metadata
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Large Oxford5k data and generated artifacts
data/raw/
data/oxford5k/images/
data/oxford5k/gt/
data/oxford5k/official_words/
data/oxford5k/smoke_images/
data/processed/

# Experiment outputs are generated by scripts
outputs/metrics/
outputs/tables/
outputs/visualizations/

# Keep lightweight directory placeholders if present
!data/.gitkeep
!data/oxford5k/.gitkeep
!outputs/.gitkeep

# Local archives and partial downloads
*.tgz
*.tar
*.tar.gz
*.zip
*.part

# Optional local course/source PDFs.
# Remove these lines if your cloud submission requires the PDFs in git.
*.pdf
*.sh
*.log
*.pid
